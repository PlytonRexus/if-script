{
  "name": "if-script",
  "version": "0.6.1-ide-next",
  "private": true,
  "description": "IF-Script IDE vNext workspace",
  "workspaces": [
    "apps/ide"
  ],
  "scripts": {
    "dev": "npm --workspace apps/ide run dev",
    "build": "npm --workspace apps/ide run build",
    "test": "npm --workspace apps/ide run test",
    "test:e2e": "npm --workspace apps/ide run test:e2e",
    "lint": "npm --workspace apps/ide run lint",
    "typecheck": "npm --workspace apps/ide run typecheck",
    "link:core": "npm link ../if-script-core",
    "unlink:core": "npm unlink if-script-core && npm install",
    "prepare": "cp scripts/pre-commit.sh .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit"
  },
  "engines": {
    "node": ">=22.13.0",
    "npm": ">=10.9.0"
  }
}
